@page
@model VisualAcademy.Pages.Cascading.Sublocations.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

@if (Model.Sublocation is null)
{
    <div class="alert alert-warning">
        The requested sublocation could not be found.
    </div>

    <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
}
else
{
    <div>
        <h4>Sublocation</h4>
        <hr />

        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Sublocation.SublocationName)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Sublocation.SublocationName)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Sublocation.Active)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Sublocation.Active)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Sublocation.Location)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Sublocation.Location)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Sublocation.Property)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Sublocation.Property)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Sublocation.LocationRef)
            </dt>
            <dd class="col-sm-10">
                @(Model.Sublocation.LocationRef?.Id.ToString() ?? "")
            </dd>
        </dl>
    </div>

    <div>
        <a asp-page="./Edit" asp-route-id="@Model.Sublocation.Id">Edit</a> |
        <a asp-page="./Index">Back to List</a>
    </div>
}
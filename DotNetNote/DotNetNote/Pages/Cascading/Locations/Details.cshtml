@page
@model VisualAcademy.Pages.Cascading.Locations.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

@if (Model.Location is null)
{
    <div class="alert alert-warning" role="alert">
        Location information was not found.
    </div>

    <div>
        <a asp-page="./Index">Back to List</a>
    </div>
}
else
{
    <div>
        <h4>Location</h4>
        <hr />

        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Location.Name)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Location.Name)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Location.Active)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Location.Active)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Location.Property)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Location.Property)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Location.PropertyRef)
            </dt>
            <dd class="col-sm-10">
                @(Model.Location.PropertyRef?.Id.ToString() ?? "-")
            </dd>
        </dl>
    </div>

    <div>
        <a asp-page="./Edit" asp-route-id="@Model.Location.Id">Edit</a> |
        <a asp-page="./Index">Back to List</a>
    </div>
}